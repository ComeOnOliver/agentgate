{
  "name": "agentgate",
  "version": "0.1.0",
  "description": "Let any Node.js project expose capabilities to AI agents in minutes",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "middleware",
    "mcp",
    "express",
    "hono",
    "api",
    "gateway",
    "llm",
    "tools",
    "schema",
    "zod"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ComeOnOliver/agentgate.git"
  },
  "bugs": {
    "url": "https://github.com/ComeOnOliver/agentgate/issues"
  },
  "homepage": "https://github.com/ComeOnOliver/agentgate#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "uuid": "^11.1.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "express": "^4.21.0",
    "hono": "^4.6.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  }
}
